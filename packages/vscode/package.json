{
  "name": "contenox-runtime",
  "displayName": "Contenox",
  "description": "Run local, reviewable AI workflows in VS Code with chat, autocomplete, sessions, tools, and human approval gates.",
  "version": "0.33.0",
  "publisher": "contenox",
  "license": "Apache-2.0",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contenox/runtime.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/contenox/runtime/issues"
  },
  "homepage": "https://contenox.com",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "contenox",
    "ai",
    "ai-workflows",
    "agent",
    "developer-agent",
    "coding-agent",
    "workflow",
    "automation",
    "local-first",
    "model-routing",
    "reviewable-workflows",
    "mcp",
    "human-in-the-loop",
    "autocomplete",
    "code-review"
  ],
  "icon": "media/contenox-icon.png",
  "main": "./dist/extension.js",
  "type": "commonjs",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:contenox.openChat",
    "onCommand:contenox.openWalkthrough",
    "onCommand:contenox.openAgentSession",
    "onCommand:contenox.diagnoseAgentSessions",
    "onCommand:contenox.askSelection",
    "onCommand:contenox.fixSelection",
    "onCommand:contenox.addSelectionToChat",
    "onCommand:contenox.fixDiagnostics",
    "onCommand:contenox.explainDiagnostics",
    "onCommand:contenox.reviewChanges",
    "onCommand:contenox.draftCommitMessage",
    "onCommand:contenox.refreshSessions",
    "onCommand:contenox.openSession",
    "onCommand:contenox.deleteSession",
    "onCommand:contenox.showStatus",
    "onCommand:contenox.showExtensionRuntimeInfo",
    "onCommand:contenox.restartRuntime",
    "onCommand:contenox.runSetup",
    "onCommand:contenox.selectProvider",
    "onCommand:contenox.selectChatModel",
    "onCommand:contenox.selectAutocompleteProvider",
    "onCommand:contenox.selectAutocompleteModel",
    "onCommand:contenox.selectHitlPolicy",
    "onCommand:contenox.selectThinkLevel",
    "onCommand:contenox.triggerAutocomplete",
    "onCommand:contenox.testAutocompleteAtCursor",
    "onCommand:contenox.enableAutocomplete",
    "onCommand:contenox.disableAutocomplete",
    "onCommand:contenox.toggleAutocomplete",
    "onCommand:contenox.showOutput",
    "onCommand:contenox.showTelemetryLog",
    "onCommand:contenox.clearTelemetryLog",
    "onCommand:contenox.testLanguageModelProvider",
    "onCommand:contenox.showMCPServers",
    "onCommand:contenox.refreshMCPServers",
    "onCommand:contenox.openToolDiff",
    "onChatParticipant:contenox",
    "onLanguageModelTool:approve_contenox_tool_call"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Contenox can show runtime status and configuration in Restricted Mode. Runtime actions that read or modify workspace files should stay disabled until the workspace is trusted.",
      "restrictedConfigurations": [
        "contenox.binaryPath",
        "contenox.dataDir",
        "contenox.autocomplete.enabled"
      ]
    }
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contenox",
          "title": "Contenox",
          "icon": "media/contenox-activity-dark.png"
        }
      ]
    },
    "views": {
      "contenox": [
        {
          "id": "contenox.controls",
          "name": "Runtime",
          "contextualTitle": "Contenox Runtime"
        },
        {
          "id": "contenox.sessions",
          "name": "Sessions",
          "contextualTitle": "Contenox Sessions"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "contenox.controls",
        "contents": "Runtime controls are available after the Contenox runtime starts.\n[Run Setup](command:contenox.runSetup)\n[Show Status](command:contenox.showStatus)"
      },
      {
        "view": "contenox.sessions",
        "contents": "Run setup once, then use Contenox chat and sessions from this view.\n[Run Setup](command:contenox.runSetup)\n[Open the walkthrough](command:contenox.openWalkthrough) or [open chat](command:contenox.openChat)."
      }
    ],
    "walkthroughs": [
      {
        "id": "getStarted",
        "title": "Get Started with Contenox",
        "description": "Set up the local Contenox runtime, open chat, and use editor-aware workflows.",
        "steps": [
          {
            "id": "setup",
            "title": "Configure a local runtime",
            "description": "Run setup to choose a provider and model for this machine.\n[Run Setup](command:contenox.runSetup)",
            "media": {
              "markdown": "walkthrough/setup.md"
            },
            "completionEvents": [
              "onCommand:contenox.internal.setupComplete"
            ]
          },
          {
            "id": "chat",
            "title": "Open Contenox chat",
            "description": "Start a workspace chat backed by your configured Contenox runtime.\n[Open Chat](command:contenox.openChat)",
            "media": {
              "markdown": "walkthrough/chat.md"
            },
            "completionEvents": [
              "onCommand:contenox.openChat"
            ]
          },
          {
            "id": "editor-context",
            "title": "Use editor context",
            "description": "Send selected code, diagnostics, or workspace changes to Contenox from editor actions.",
            "media": {
              "markdown": "walkthrough/editor-context.md"
            },
            "completionEvents": [
              "onCommand:contenox.askSelection",
              "onCommand:contenox.fixDiagnostics",
              "onCommand:contenox.reviewChanges"
            ]
          },
          {
            "id": "sessions",
            "title": "Resume sessions",
            "description": "Use the Contenox Sessions view to reopen, refresh, or delete local chat sessions.\n[Show Sessions](command:workbench.view.extension.contenox)",
            "media": {
              "markdown": "walkthrough/sessions.md"
            },
            "completionEvents": [
              "onCommand:contenox.openSession"
            ]
          },
          {
            "id": "autocomplete",
            "title": "Try inline autocomplete",
            "description": "Trigger or test inline suggestions from your configured autocomplete model.\n[Test Autocomplete](command:contenox.testAutocompleteAtCursor)",
            "media": {
              "markdown": "walkthrough/autocomplete.md"
            },
            "completionEvents": [
              "onCommand:contenox.testAutocompleteAtCursor",
              "onCommand:contenox.triggerAutocomplete"
            ]
          }
        ]
      }
    ],
