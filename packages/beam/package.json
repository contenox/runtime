{
  "name": "@contenox/beam",
  "private": true,
  "version": "0.6.5",
  "description": "Contenox web chat UI \u2014 model conversations and task-chain runs, with optional control-plane tools.",
  "type": "module",
  "exports": {
    "./chat": {
      "types": "./src/chat/index.ts",
      "import": "./src/chat/index.ts",
      "default": "./src/chat/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:proxy": "vite --mode proxy",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b --force",
    "format": "npm run prettier:check && npm run prettier:write",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "prettier": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "dependencies": {
    "@contenox/ui": "file:../ui",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@tailwindcss/vite": "^4.0.13",
    "@tanstack/react-query": "^5.90.2",
    "clsx": "^2.1.1",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.477.0",
    "monaco-editor": "^0.53.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.4.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.3.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.13",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.6",
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  }
}
