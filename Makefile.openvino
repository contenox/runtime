PROJECT_ROOT := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))
include $(PROJECT_ROOT)mk/openvino-flags.mk

OPENVINO_MODEL ?= $(OPENVINO_WORKDIR)/models/qwen-coder-0.5b-int4
OPENVINO_REPO ?= OpenVINO/Qwen2.5-Coder-0.5B-Instruct-int4-ov
OPENVINO_DEVICE ?= CPU
OPENVINO_GENAI_REPO ?= $(HOME)/src/github.com/openvinotoolkit/openvino.genai

.PHONY: help deps deps-genai genai-src model test test-genai test-genai-scheduler test-genai-prefix-cache test-genai-context-cache clean

help:
	@echo "deps                       create .openvino venv and install OpenVINO SDK"
	@echo "deps-genai                 install OpenVINO GenAI into the .openvino venv"
	@echo "genai-src                  fetch matching OpenVINO GenAI C++ headers"
	@echo "model                      download the tiny OpenVINO IR test model"
	@echo "test                       run the build-tagged OpenVINO KV round-trip test"
	@echo "test-genai                 run OpenVINO GenAI provider/session tests"
	@echo "test-genai-scheduler       run GenAI SchedulerConfig tests"
	@echo "test-genai-prefix-cache    run GenAI prefix-cache warm-reuse test"
	@echo "test-genai-context-cache   run context assembler prefix-cache tests"
	@echo "clean                      remove .openvino"

deps:
	$(PYTHON) -m venv "$(OPENVINO_VENV)"
	@if [ "$(shell go env GOOS 2>/dev/null)" = "windows" ]; then \
		"$(OPENVINO_VENV)/Scripts/python.exe" -m pip install -q --upgrade pip; \
		"$(OPENVINO_VENV)/Scripts/pip" install -q openvino huggingface_hub; \
	else \
		"$(OPENVINO_VENV)/bin/pip" install -q --upgrade pip; \
		"$(OPENVINO_VENV)/bin/pip" install -q openvino huggingface_hub; \
	fi

deps-genai: deps
	@if [ "$(shell go env GOOS 2>/dev/null)" = "windows" ]; then \
		"$(OPENVINO_VENV)/Scripts/pip" install -q openvino-genai; \
	else \
		"$(OPENVINO_VENV)/bin/pip" install -q openvino-genai; \
	fi

genai-src:
	test -d "$(OPENVINO_GENAI_REPO)/.git" || git clone https://github.com/openvinotoolkit/openvino.genai.git "$(OPENVINO_GENAI_REPO)"
	git -C "$(OPENVINO_GENAI_REPO)" fetch --tags --force
	test -d "$(OPENVINO_GENAI_SRC)" || git -C "$(OPENVINO_GENAI_REPO)" worktree add --detach "$(OPENVINO_GENAI_SRC)" "$(OPENVINO_GENAI_VERSION)"
	test -f "$(OPENVINO_GENAI_SRC)/build/_deps/nlohmann_json-src/single_include/nlohmann/json.hpp" || (mkdir -p "$(OPENVINO_GENAI_SRC)/build/_deps" && curl -fsSL https://github.com/nlohmann/json/archive/refs/tags/v3.11.3.tar.gz | tar -xz -C "$(OPENVINO_GENAI_SRC)/build/_deps" && mv "$(OPENVINO_GENAI_SRC)/build/_deps/json-3.11.3" "$(OPENVINO_GENAI_SRC)/build/_deps/nlohmann_json-src")
	test -f "$(OPENVINO_GENAI_SRC)/build/_deps/minja-src/include/minja/minja.hpp" || (mkdir -p "$(OPENVINO_GENAI_SRC)/build/_deps" && git clone https://github.com/google/minja.git "$(OPENVINO_GENAI_SRC)/build/_deps/minja-src" && git -C "$(OPENVINO_GENAI_SRC)/build/_deps/minja-src" checkout 3e4c61c616eda133cfb1e440fc7a14bf1729bbee)
	test -f "$(OPENVINO_GENAI_SRC)/build/_deps/safetensors.h-src/safetensors.h" || (mkdir -p "$(OPENVINO_GENAI_SRC)/build/_deps" && curl -fsSL https://github.com/hsnyder/safetensors.h/archive/974a85d7dfd6e010558353226638bb26d6b9d756.tar.gz | tar -xz -C "$(OPENVINO_GENAI_SRC)/build/_deps" && mv "$(OPENVINO_GENAI_SRC)/build/_deps/safetensors.h-974a85d7dfd6e010558353226638bb26d6b9d756" "$(OPENVINO_GENAI_SRC)/build/_deps/safetensors.h-src")
	test -f "$(OPENVINO_GENAI_SRC)/build/_deps/gguflib-src/gguflib.h" || (mkdir -p "$(OPENVINO_GENAI_SRC)/build/_deps" && git clone https://github.com/Lourdle/gguf-tools.git "$(OPENVINO_GENAI_SRC)/build/_deps/gguflib-src" && git -C "$(OPENVINO_GENAI_SRC)/build/_deps/gguflib-src" checkout bac796ada809ac293e685db59b075971181cb008)

model: deps
	"$(OPENVINO_VENV)/bin/python" -c 'from huggingface_hub import snapshot_download; snapshot_download(repo_id="$(OPENVINO_REPO)", local_dir="$(OPENVINO_MODEL)")'

test: model
	CGO_ENABLED=1 \
	CGO_CXXFLAGS="$(OPENVINO_CGO_CXXFLAGS)" \
	CGO_LDFLAGS="$(OPENVINO_CGO_LDFLAGS)" \
	LD_LIBRARY_PATH="$(OPENVINO_PKG)/libs" \
	CONTENOX_OPENVINO_TEST_MODEL="$(OPENVINO_MODEL)" \
	CONTENOX_OPENVINO_TEST_DEVICE="$(OPENVINO_DEVICE)" \
	go test -tags openvino -run 'Test(System_OpenVINOSession|Unit_OpenVINO)' -v ./modeld/openvino/...

test-genai-scheduler: model deps-genai genai-src
	CGO_ENABLED=1 \
	CGO_CXXFLAGS="$(OPENVINO_GENAI_CGO_CXXFLAGS)" \
	CGO_LDFLAGS="$(OPENVINO_GENAI_CGO_LDFLAGS)" \
	LD_LIBRARY_PATH="$(OPENVINO_PKG)/libs:$(OPENVINO_GENAI_PKG):$(OPENVINO_TOKENIZERS_LIB)" \
	OPENVINO_TOKENIZERS_PATH_GENAI="$(OPENVINO_TOKENIZERS_SO)" \
	CONTENOX_OPENVINO_TEST_MODEL="$(OPENVINO_MODEL)" \
	CONTENOX_OPENVINO_TEST_DEVICE="$(OPENVINO_DEVICE)" \
	go test -tags 'openvino openvino_genai' -run TestSystem_OpenVINOGenAI_SchedulerControlsReachable -v ./modeld/openvino/ovsession

test-genai: model deps-genai genai-src
	CGO_ENABLED=1 \
	CGO_CXXFLAGS="$(OPENVINO_GENAI_CGO_CXXFLAGS)" \
	CGO_LDFLAGS="$(OPENVINO_GENAI_CGO_LDFLAGS)" \
	LD_LIBRARY_PATH="$(OPENVINO_PKG)/libs:$(OPENVINO_GENAI_PKG):$(OPENVINO_TOKENIZERS_LIB)" \
	OPENVINO_TOKENIZERS_PATH_GENAI="$(OPENVINO_TOKENIZERS_SO)" \
	CONTENOX_OPENVINO_TEST_MODEL="$(OPENVINO_MODEL)" \
	CONTENOX_OPENVINO_TEST_DEVICE="$(OPENVINO_DEVICE)" \
	go test -tags 'openvino openvino_genai' -v ./modeld/openvino/...

test-genai-prefix-cache: model deps-genai genai-src
	CGO_ENABLED=1 \
	CGO_CXXFLAGS="$(OPENVINO_GENAI_CGO_CXXFLAGS)" \
	CGO_LDFLAGS="$(OPENVINO_GENAI_CGO_LDFLAGS)" \
	LD_LIBRARY_PATH="$(OPENVINO_PKG)/libs:$(OPENVINO_GENAI_PKG):$(OPENVINO_TOKENIZERS_LIB)" \
	OPENVINO_TOKENIZERS_PATH_GENAI="$(OPENVINO_TOKENIZERS_SO)" \
	CONTENOX_OPENVINO_TEST_MODEL="$(OPENVINO_MODEL)" \
	CONTENOX_OPENVINO_TEST_DEVICE="$(OPENVINO_DEVICE)" \
	go test -tags 'openvino openvino_genai' -run TestSystem_OpenVINOGenAI_PrefixReuseWarmsPrefill -v ./modeld/openvino/ovsession

test-genai-context-cache: model deps-genai genai-src
	CGO_ENABLED=1 \
	CGO_CXXFLAGS="$(OPENVINO_GENAI_CGO_CXXFLAGS)" \
	CGO_LDFLAGS="$(OPENVINO_GENAI_CGO_LDFLAGS)" \
	LD_LIBRARY_PATH="$(OPENVINO_PKG)/libs:$(OPENVINO_GENAI_PKG):$(OPENVINO_TOKENIZERS_LIB)" \
	OPENVINO_TOKENIZERS_PATH_GENAI="$(OPENVINO_TOKENIZERS_SO)" \
	CONTENOX_OPENVINO_TEST_MODEL="$(OPENVINO_MODEL)" \
	CONTENOX_OPENVINO_TEST_DEVICE="$(OPENVINO_DEVICE)" \
	go test -tags 'openvino openvino_genai' -run 'TestSystem_OpenVINOSegments_AssemblerDrivesPrefixCache|TestSystem_OpenVINOChatContext_ClassifierWarmsChatPath' -v ./modeld/openvino/

clean:
	rm -rf "$(OPENVINO_WORKDIR)"
