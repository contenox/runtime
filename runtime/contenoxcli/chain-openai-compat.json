{
  "id": "chain-openai-compat",
  "description": "OpenAI compat chat chain — single chat_completion task, no tools, model and provider resolved from template vars.",
  "tasks": [
    {
      "id": "compat_chat",
      "handler": "chat_completion",
      "system_instruction": "Current date: {{date}}.",
      "execute_config": {
        "model": "{{var:model}}",
        "provider": "{{var:provider}}",
        "tools": [],
        "max_tokens": "{{var:max_tokens|8192}}"
      },
      "transition": {
        "branches": [
          {
            "operator": "default",
            "when": "",
            "goto": "end"
          }
        ]
      }
    }
  ]
}
