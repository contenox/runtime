---
import type { TreeNode } from '../lib/tree';

interface Props {
  node: TreeNode;
  current: string;
}
const { node, current } = Astro.props;

const containsCurrent = (n: TreeNode): boolean =>
  n.url === current || n.children.some(containsCurrent);
---
{node.url ? (
  <li>
    <a
      href={node.url}
      aria-current={node.url === current ? 'page' : undefined}
      class:list={[
        'block rounded px-2 py-1 text-sm no-underline transition-colors',
        node.url === current
          ? 'bg-neutral-100 font-semibold text-black dark:bg-neutral-900 dark:text-white'
          : 'text-neutral-600 hover:text-black dark:text-neutral-400 dark:hover:text-white',
      ]}
    >{node.title ?? node.name}</a>
  </li>
) : (
  <li>
    <details open={containsCurrent(node)}>
      <summary class="cursor-pointer rounded px-2 py-1 font-mono text-sm text-neutral-700 select-none hover:text-black dark:text-neutral-300 dark:hover:text-white">{node.name}/</summary>
      <ul class="ml-3 border-l border-neutral-200 pl-1 dark:border-neutral-800">
        {node.children.map((child) => (
          <Astro.self node={child} current={current} />
        ))}
      </ul>
    </details>
  </li>
)}
