# ==============================
# Go
# ==============================

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries (built with `go test -c`)
*.test

# Coverage and profiling
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace
go.work
go.work.sum

vendor/

# ==============================
# Python
# ==============================

__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# ==============================
# General / OS / IDE
# ==============================

# Secrets & config
.env
.envrc
.env.*
!.env.example

# Logs
*.log
logs/

# Certificates / keys
*.pem
*.key
*.crt

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*.suo

# OS
.DS_Store
Thumbs.db

# Temporary / local
*.local
tmp/
temp/
node_modules/
.air.serve.toml

# ==============================
# Project-specific
# ==============================

# Contenox CLI build output and local config
bin/
.contenox/

# Beam UI build output (embedded into Go binary via //go:embed at build time)
runtime/internal/web/beam/dist/*
!runtime/internal/web/beam/dist/.gitkeep

# Storybook build output
packages/ui/storybook-static/

# Local AI context control
.cursorignore
.cursorindexingignore

# Ollama local data
.ollama/

# Enterprise (optional local checkout — not tracked)
enterprise/

.apikey.txt

.notes/
.claude
