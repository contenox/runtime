---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { entryTitle, published } from '../../lib/entries';

const entries = (await getCollection('stories', published)).sort((a, b) =>
  a.id.localeCompare(b.id),
);
---
<Base title="Contenox Stories">
  <div class="mx-auto max-w-3xl px-5 py-10">
    <h1 class="text-3xl font-bold tracking-tight">Stories</h1>
    <ul class="mt-6 divide-y divide-neutral-200 dark:divide-neutral-900">
      {entries.map((entry) => (
        <li>
          <a href={`/stories/${entry.id}/`} class="group flex flex-wrap items-baseline gap-x-3 py-2.5 no-underline">
            <span class="font-medium group-hover:underline">{entryTitle(entry)}</span>
            {entry.data.description && <span class="text-sm text-neutral-500">{entry.data.description}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>
