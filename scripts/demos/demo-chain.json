{
  "id": "chain-demo",
  "description": "Demo chain: default policies plus rm/touch allowed (HITL still gates rm).",
  "tasks": [
    {
      "id": "classify_request",
      "description": "Route the latest chat prompt to the coding loop or the general assistant loop.",
      "handler": "route",
      "system_instruction": "Current date: {{date}}.\n\nClassify the user's latest message. Use 'coding_change' for requests to create, edit, migrate, refactor, fix, test, build, or otherwise change code/files. Use 'general' for questions, explanations, brainstorming, setup help, UI/settings discussion, or anything that should use the normal assistant loop.",
      "execute_config": {
        "model": "{{var:alt_model|var:model}}",
        "provider": "{{var:alt_provider|var:provider}}",
        "shift": true,
        "tools": [],
        "retry_policy": {
          "max_attempts": 3,
          "initial_backoff": "1s",
          "max_backoff": "10s",
          "jitter": 0.25
        }
      },
      "transition": {
        "on_failure": "contenox_chat",
        "branches": [
          {
            "operator": "equals",
            "when": "coding_change",
            "goto": "coding_chat"
          },
          {
            "operator": "equals",
            "when": "general",
            "goto": "contenox_chat"
          },
          {
            "operator": "default",
            "when": "",
            "goto": "contenox_chat"
          }
        ]
      }
    },
    {
      "id": "coding_chat",
      "description": "Coding specialist loop. The model may call tools repeatedly or finish directly.",
      "handler": "chat_completion",
      "system_instruction": "Current date: {{date}}.\n\nYou are Contenox in a web chat, acting as a coding and file-change specialist.\n\nOwn the whole coding turn in this loop: inspect the workspace when needed, make the requested changes, run the relevant checks, and then answer with what changed and what verification ran. Do not wait for a separate planning, patching, verification, or audit task to take over.\n\nREFUSE UNCLEAR: If the request is ambiguous or under-specified, ask one focused clarifying question and take no destructive or speculative action until the user answers.\n\nWORKING RULES: Read before editing existing files. Keep changes small and consistent with the repo. Do not destructively move, delete, or overwrite user content unless explicitly requested. Prefer direct progress over repeatedly re-reading the same context.\n\nGROUND YOUR CLAIMS: State facts about files, code, or command results only from tool output in this turn. If a tool errors, returns nothing, or cannot read something, say so plainly instead of substituting a guess.",
      "execute_config": {
        "model": "{{var:model}}",
        "provider": "{{var:provider}}",
        "think": "{{var:think}}",
        "shift": true,
        "pass_clients_tools": false,
        "tools": [
          "*"
        ],
        "tools_policies": {
          "local_shell": {
            "_allowed_commands": "ls,cat,echo,pwd,which,find,grep,git,go,python3,node,npm,npx,pnpm,yarn,bun,make,cargo,pytest,curl,wget,jq,rm,touch",
            "_denied_commands": "sudo,su,dd,mkfs,fdisk,parted,shred"
          },
          "local_fs": {
            "_allowed_dir": ".",
            "_max_read_bytes": "262144",
            "_max_output_bytes": "131072",
            "_max_list_depth": "5",
            "_max_grep_matches": "1000",
            "_denied_path_substrings": "node_modules,.git/,dist/,/.next/,/out/,package-lock.json",
            "_skip_dir_names": ".git,node_modules,.venv,__pycache__,.next,dist,.cache,vendor,target,.idea,.vscode,out"
          },
          "webtools": {
            "_max_response_bytes": "262144",
            "_max_request_body_bytes": "262144",
            "_request_timeout_seconds": "30",
            "_max_attempts": "3"
          }
        },
        "max_tokens": "{{var:max_tokens|16384}}",
        "retry_policy": {
          "max_attempts": 4,
          "initial_backoff": "1s",
          "max_backoff": "30s",
          "jitter": 0.25,
          "rate_limit_min_wait": "10s"
        }
      },
      "transition": {
        "on_failure": "coding_recovery",
        "branches": [
          {
            "operator": "edge_traversed_at_least",
            "edge": "coding_chat->coding_tools",
            "when": "12",
            "goto": "coding_recovery"
          },
          {
            "operator": "equals",
            "when": "tool_call",
            "goto": "coding_tools"
          },
          {
            "operator": "default",
            "when": "",
            "goto": "end"
          }
        ]
      }
    },
    {
      "id": "coding_tools",
      "description": "Execute coding-loop tool calls and append results to chat history.",
      "handler": "execute_tool_calls",
      "input_var": "coding_chat",
      "execute_config": {
        "tools": [
