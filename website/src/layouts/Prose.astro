---
import Base from './Base.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const current = Astro.url.pathname;

// Map the URL path to the source file in the repo. All content lives under
// docs/ (cookbook/stories routes drop the prefix), and readme slugs come
// from README.md files.
const segments = current.replace(/^\//, '').replace(/\/$/, '').split('/');
if (segments[0] !== 'docs') segments.unshift('docs');
if (segments[segments.length - 1] === 'readme') segments[segments.length - 1] = 'README';
const docPath = segments.join('/') + '.md';
const editUrl = `https://github.com/contenox/runtime/blob/main/${docPath}`;

// Blueprints are design records: browsable, but kept out of search engines.
const noindex = current.startsWith('/docs/development/blueprints/');
---
<Base {...Astro.props} ogType="article" noindex={noindex}>
  <div class="mx-auto flex max-w-6xl gap-8 px-5">
    <aside class="sticky top-13 hidden max-h-[calc(100vh-3.25rem)] w-64 shrink-0 overflow-y-auto py-10 lg:block">
      <Sidebar current={current} />
    </aside>
    <div class="min-w-0 flex-1">
      <details class="mt-6 rounded-lg border border-neutral-200 px-3 py-2 lg:hidden dark:border-neutral-800">
        <summary class="cursor-pointer text-sm font-semibold select-none">Browse docs/</summary>
        <div class="pt-3"><Sidebar current={current} /></div>
      </details>
      <article data-pagefind-body class="prose prose-compact prose-neutral dark:prose-invert max-w-3xl py-10 prose-img:rounded-lg prose-img:border prose-img:border-neutral-200 dark:prose-img:border-neutral-800 prose-code:before:content-none prose-code:after:content-none">
        <slot />
      </article>
      <div class="max-w-3xl border-t border-neutral-100 pt-4 pb-10 dark:border-neutral-800/60">
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-xs text-neutral-400 no-underline transition-colors hover:text-indigo-600 dark:text-neutral-600 dark:hover:text-indigo-400"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          Edit this page on GitHub
        </a>
      </div>
    </div>
  </div>
</Base>

