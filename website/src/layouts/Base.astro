---
import '../styles/global.css';
import { buildNavSections } from '../lib/tree';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogType?: string;
  /** hreflang alternates for translated pages, e.g. { en: '/', de: '/de/' } */
  alternates?: Record<string, string>;
  noindex?: boolean;
}
const {
  title,
  description = 'Contenox — local-first AI workflow runtime. Package repeatable work into versioned chains and run them from the CLI, VS Code, or any ACP editor.',
  lang = 'en',
  ogType = 'website',
  alternates,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/opengraph-image.png', Astro.site);

const t = lang === 'de'
  ? { start: 'Loslegen', theme: 'Farbschema umschalten', tagline: 'Lokale Runtime für nachvollziehbare KI-Workflows.' }
  : { start: 'Get Started', theme: 'Toggle theme', tagline: 'Local runtime for auditable AI workflows.' };

const navSections = await buildNavSections();
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    {alternates && Object.entries(alternates).map(([hl, path]) => (
      <link rel="alternate" hreflang={hl} href={new URL(path, Astro.site)} />
    ))}
    {alternates && <link rel="alternate" hreflang="x-default" href={new URL(alternates.en ?? '/', Astro.site)} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-light.ico" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark.ico" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/icon-dark.png" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Contenox" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Theme: class strategy; resolve before paint to avoid flash. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
  </head>
  <body class="bg-surface-50 text-text dark:bg-dark-surface-100 dark:text-dark-text font-sans antialiased min-h-screen flex flex-col">
    <header class="sticky top-0 z-10 border-b border-neutral-200/50 bg-white/70 backdrop-blur-xl dark:border-neutral-800/50 dark:bg-black/70">
      <div class="mx-auto flex h-13 max-w-6xl items-center gap-6 px-5">
        <a href={lang === 'de' ? '/de/' : '/'} class="mr-auto flex items-center gap-2 text-lg font-semibold tracking-tight no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="26" height="26" fill="currentColor" aria-hidden="true">
            <path d="M207.28,164.77h170.47v-84.96h0c-54.58,0-106.94,21.64-145.6,60.17l-24.87,24.79Z" />
            <path d="M207.21,164.77v170.47h-84.96c0-54.58,21.64-106.94,60.17-145.6l24.79-24.87Z" />
            <path d="M207.21,335.23h170.47s0,84.96,0,84.96h0c-54.58,0-106.94-21.64-145.6-60.17l-24.87-24.79Z" />
          </svg>
          contenox
        </a>
        <nav class="flex items-center gap-5 text-sm font-medium">
          {navSections.map((s) => (
            <a href={s.url} class="hidden capitalize text-neutral-600 transition-colors hover:text-indigo-600 sm:inline dark:text-neutral-400 dark:hover:text-indigo-400">{s.name}</a>
          ))}
          <a href="https://github.com/contenox/runtime" class="text-neutral-600 transition-colors hover:text-indigo-600 dark:text-neutral-400 dark:hover:text-indigo-400">GitHub</a>
          <button id="search-open" type="button" aria-label="Search" title="Search ( / )" class="cursor-pointer rounded-lg border border-neutral-200 p-1.5 text-neutral-600 transition-colors hover:text-black dark:border-neutral-800 dark:text-neutral-400 dark:hover:text-white">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
          <button id="theme-toggle" type="button" aria-label={t.theme} class="cursor-pointer rounded-lg border border-neutral-200 p-1.5 text-neutral-600 transition-colors hover:text-black dark:border-neutral-800 dark:text-neutral-400 dark:hover:text-white">
            <svg class="hidden h-4 w-4 dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
            <svg class="block h-4 w-4 dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
          </button>
          <a href="/docs/guide/quickstart/" class="rounded-lg bg-gradient-to-r from-indigo-500 to-violet-600 px-3.5 py-1.5 font-semibold text-white shadow-md shadow-indigo-500/20 transition-all hover:scale-105 hover:shadow-indigo-500/40">{t.start}</a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <dialog id="search-dialog" class="m-auto w-full max-w-2xl rounded-xl border border-neutral-200 bg-white p-4 shadow-2xl backdrop:bg-black/50 dark:border-neutral-800 dark:bg-neutral-950">
      <div id="pagefind-search"></div>
      <p class="mt-3 text-right text-xs text-neutral-500">Esc to close</p>
    </dialog>
    <footer class="border-t border-neutral-200 dark:border-neutral-800">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-5 py-6 text-sm text-neutral-500">
        <span>{t.tagline} © 2026 Contenox. Apache-2.0.</span>
        <nav class="flex gap-4">
          <a href="mailto:hello@contenox.com" class="hover:text-black dark:hover:text-white">hello@contenox.com</a>
          <a href="https://github.com/contenox/runtime" class="hover:text-black dark:hover:text-white">GitHub</a>
          <a href="/docs/" class="hover:text-black dark:hover:text-white">Docs</a>
          <a href="/docs/use-cases/" class="hover:text-black dark:hover:text-white">Use cases</a>
          <a href="/legal/" class="hover:text-black dark:hover:text-white">Legal</a>
          {lang === 'de'
            ? <a href="/" class="hover:text-black dark:hover:text-white">English</a>
            : <a href="/de/" class="hover:text-black dark:hover:text-white">Deutsch</a>}
        </nav>
      </div>
    </footer>
    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const dark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', dark ? 'dark' : 'light');
      });
      (() => {
        const dialog = document.getElementById('search-dialog');
        let loaded = false;
        const open = async () => {
          if (!loaded) {
            loaded = true;
            const css = document.createElement('link');
            css.rel = 'stylesheet';
            css.href = '/pagefind/pagefind-ui.css';
            document.head.appendChild(css);
            await new Promise((resolve, reject) => {
              const s = document.createElement('script');
              s.src = '/pagefind/pagefind-ui.js';
              s.onload = resolve;
              s.onerror = reject;
              document.head.appendChild(s);
            }).catch(() => {});
            if (window.PagefindUI) {
              new window.PagefindUI({ element: '#pagefind-search', showSubResults: true, showImages: false });
            } else {
              document.getElementById('pagefind-search').textContent =
                'Search index not built yet — run the production build.';
            }
          }
          dialog.showModal();
          dialog.querySelector('input')?.focus();
        };
        document.getElementById('search-open')?.addEventListener('click', open);
        document.addEventListener('keydown', (e) => {
          if ((e.key === '/' || (e.key === 'k' && (e.ctrlKey || e.metaKey))) && !dialog.open &&
              !/^(INPUT|TEXTAREA)$/.test(document.activeElement?.tagName ?? '')) {
            e.preventDefault();
            open();
          }
        });
        dialog?.addEventListener('click', (e) => {
          if (e.target === dialog) dialog.close();
        });
      })();
      document.querySelectorAll('pre').forEach((pre) => {
        const code = pre.querySelector('code') ?? pre;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-copy-btn';
        btn.textContent = 'Copy';
        btn.setAttribute('aria-label', 'Copy code to clipboard');
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(code.innerText.trimEnd());
            btn.textContent = 'Copied';
          } catch {
            btn.textContent = 'Failed';
          }
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        });
        pre.appendChild(btn);
      });
    </script>
  </body>
</html>
