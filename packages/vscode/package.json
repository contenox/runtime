    "chatParticipants": [
      {
        "id": "contenox",
        "name": "contenox",
        "fullName": "Contenox",
        "description": "Use the local Contenox runtime for codebase chat, fixes, and automation.",
        "isSticky": true,
        "sampleRequest": "Summarize this workspace",
        "commands": [
          {
            "name": "fix",
            "description": "Fix active diagnostics or selected code with Contenox",
            "sampleRequest": "Type 'undefined' is not assignable to type 'string'."
          },
          {
            "name": "explain",
            "description": "Explain selected code or active diagnostics"
          },
          {
            "name": "doctor",
            "description": "Check Contenox provider and model readiness"
          },
          {
            "name": "review",
            "description": "Review current git changes"
          },
          {
            "name": "commit",
            "description": "Draft a commit message for current git changes"
          },
          {
            "name": "compact",
            "description": "Compact older session history"
          },
          {
            "name": "policy",
            "description": "Show or set the active Contenox HITL policy"
          },
          {
            "name": "websearch",
            "description": "Search the web through the Contenox runtime"
          }
        ]
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "contenox",
        "displayName": "Contenox",
        "managementCommand": "contenox.runSetup"
      }
    ],
    "languageModelTools": [
      {
        "name": "approve_contenox_tool_call",
        "displayName": "Approve Contenox Tool Call",
        "toolReferenceName": "approveContenoxToolCall",
        "modelDescription": "Requests native VS Code confirmation for a Contenox HITL policy-gated tool call. The tool only records the user's approval decision; the Contenox runtime executes or denies the original tool call after the approval result is returned.",
        "userDescription": "Review a Contenox HITL policy-gated tool call before it runs.",
        "canBeReferencedInPrompt": false,
        "tags": [
          "contenox",
          "approval"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "approvalId": {
              "type": "string",
              "description": "Opaque Contenox approval request id."
            },
            "title": {
              "type": "string",
              "description": "Human-readable title for the tool call that needs approval."
            },
            "toolName": {
              "type": "string",
              "description": "Runtime tool name, if available."
            },
            "toolsName": {
              "type": "string",
              "description": "Runtime tool namespace, if available."
            },
            "policyName": {
              "type": "string",
              "description": "Active HITL policy name, if available."
            },
            "policyPath": {
              "type": "string",
              "description": "Active HITL policy file path, if available."
            },
            "summary": {
              "type": "string",
              "description": "Short plain-text approval summary."
            },
            "input": {
              "type": "object",
              "description": "Structured tool input that Contenox is asking to run."
            },
            "inputJson": {
              "type": "string",
              "description": "Pretty-printed tool input for the approval card."
            },
            "diff": {
              "type": "string",
              "description": "Unified diff for the proposed change, if available."
            },
            "currentContent": {
              "type": "string",
              "description": "Current content for a proposed edit, if available."
            },
            "proposedContent": {
              "type": "string",
              "description": "Proposed content for a proposed edit, if available."
            }
          },
          "required": [
            "approvalId",
            "title",
            "summary"
          ]
        }
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "contenox.mcpServers",
        "label": "Contenox MCP Servers"
      }
    ],
    "configuration": {
      "title": "Contenox",
      "properties": {
        "contenox.binaryPath": {
          "type": "string",
          "default": "contenox",
          "description": "Path to the Contenox CLI binary. The extension uses its bundled bin/contenox when this is left as contenox and the bundled binary exists. Use a remote/container path when the workspace is remote."
        },
        "contenox.dataDir": {
          "type": "string",
          "default": "",
          "description": "Optional Contenox data directory passed to the runtime command."
        },
        "contenox.startOnActivation": {
          "type": "boolean",
          "default": true,
          "description": "Start the Contenox runtime connection when the VS Code extension activates."
        },
        "contenox.requestTimeoutMs": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for Contenox runtime requests."
        },
        "contenox.logProtocol": {
          "type": "boolean",
          "default": false,
          "description": "Write redacted runtime protocol traffic to the Contenox Protocol output channel."
        },
        "contenox.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Write local diagnostic JSONL events to the Contenox data directory. No events are sent to a remote service."
        },
        "contenox.autocompleteProvider": {
          "type": "string",
          "default": "",
          "description": "Optional workspace provider override for inline autocomplete. Use this to route ghost text to local modeld, local-network Ollama, or a cloud code model. Empty uses Contenox runtime autocomplete defaults."
        },
        "contenox.autocompleteModel": {
          "type": "string",
          "default": "",
          "description": "Optional workspace model override for inline autocomplete, independent from the chat model. Empty uses Contenox runtime autocomplete defaults."
        },
        "contenox.maxOutputTokens": {
          "type": "number",
          "default": 128,
          "minimum": 16,
          "description": "Default maximum output tokens for lightweight editor requests."
        },
        "contenox.autocomplete.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Request Contenox inline completions from VS Code editors. Disabled by default; enable deliberately after choosing or accepting an autocomplete provider/model."
        },
        "contenox.autocomplete.maxPrefixChars": {
          "type": "number",
          "default": 6000,
          "minimum": 256,
          "description": "Maximum number of characters before the cursor sent for inline completion."
        },
        "contenox.autocomplete.maxSuffixChars": {
          "type": "number",
          "default": 2000,
          "minimum": 0,
          "description": "Maximum number of characters after the cursor sent for inline completion."
        },
        "contenox.autocomplete.maxTokens": {
          "type": "number",
          "default": 128,
          "minimum": 16,
          "description": "Maximum completion tokens requested from the Contenox FIM chain."
        },
        "contenox.autocomplete.maxDocumentChars": {
          "type": "number",
          "default": 200000,
          "minimum": 1000,
          "description": "Maximum document size eligible for inline autocomplete requests."
        },
        "contenox.autocomplete.debounceMs": {
          "type": "number",
          "default": 180,
          "minimum": 0,
          "description": "Debounce delay for automatic inline autocomplete requests."
        },
        "contenox.experimental.nativeAgentSessions": {
          "type": "boolean",
          "default": false,
          "description": "Enable the proposed VS Code native chat session provider. Disabled by default so the Contenox sidebar remains the authoritative session list."
        }
      }
    },
    "submenus": [
      {
        "id": "contenox.editor",
        "label": "Contenox"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "contenox.openChat"
        },
        {
          "command": "contenox.openWalkthrough"
        },
        {
          "command": "contenox.openAgentSession"
        },
        {
          "command": "contenox.diagnoseAgentSessions"
        },
        {
          "command": "contenox.askSelection"
        },
        {
          "command": "contenox.fixSelection"
        },
        {
          "command": "contenox.addSelectionToChat"
        },
        {
          "command": "contenox.fixDiagnostics"
        },
        {
          "command": "contenox.explainDiagnostics"
        },
        {
          "command": "contenox.reviewChanges"
        },
        {
          "command": "contenox.draftCommitMessage"
        },
        {
          "command": "contenox.showStatus"
        },
        {
          "command": "contenox.showExtensionRuntimeInfo"
        },
        {
          "command": "contenox.restartRuntime",
          "when": "!contenox.turnInProgress"
        },
        {
          "command": "contenox.runSetup",
          "when": "!contenox.turnInProgress"
        },
        {
          "command": "contenox.selectProvider"
        },
        {
          "command": "contenox.selectChatModel"
        },
        {
          "command": "contenox.selectAutocompleteProvider"
        },
        {
          "command": "contenox.selectAutocompleteModel"
        },
        {
          "command": "contenox.selectHitlPolicy"
        },
        {
          "command": "contenox.selectThinkLevel"
        },
        {
          "command": "contenox.triggerAutocomplete"
        },
        {
          "command": "contenox.testAutocompleteAtCursor"
        },
        {
          "command": "contenox.enableAutocomplete"
        },
        {
          "command": "contenox.disableAutocomplete"
        },
        {
          "command": "contenox.toggleAutocomplete"
        },
        {
          "command": "contenox.showOutput"
        },
        {
          "command": "contenox.showTelemetryLog"
        },
        {
          "command": "contenox.clearTelemetryLog"
        },
        {
          "command": "contenox.testLanguageModelProvider"
        },
        {
          "command": "contenox.showMCPServers"
        },
        {
          "command": "contenox.refreshMCPServers"
        }
      ],
      "editor/context": [
        {
          "submenu": "contenox.editor",
          "when": "isWorkspaceTrusted",
          "group": "navigation@80"
        }
      ],
      "contenox.editor": [
        {
          "command": "contenox.askSelection",
          "when": "editorHasSelection && isWorkspaceTrusted",
          "group": "contenox@1"
        },
        {
          "command": "contenox.fixSelection",
          "when": "editorHasSelection && !editorReadonly && isWorkspaceTrusted",
          "group": "contenox@2"
        },
        {
          "command": "contenox.addSelectionToChat",
          "when": "editorHasSelection && isWorkspaceTrusted",
          "group": "contenox@3"
        },
        {
          "command": "contenox.fixDiagnostics",
          "when": "contenox.hasDiagnostics && isWorkspaceTrusted",
          "group": "contenox@4"
        },
        {
          "command": "contenox.explainDiagnostics",
          "when": "contenox.hasDiagnostics && isWorkspaceTrusted",
          "group": "contenox@5"
        }
      ],
      "editor/context/chat": [
        {
          "command": "contenox.fixSelection",
          "when": "editorHasSelection && !editorReadonly && isWorkspaceTrusted",
          "group": "contenoxAction@1"
        },
        {
          "command": "contenox.askSelection",
          "when": "editorHasSelection && isWorkspaceTrusted",
          "group": "contenoxAction@2"
        },
        {
          "command": "contenox.addSelectionToChat",
          "when": "editorHasSelection && isWorkspaceTrusted",
          "group": "contenoxAction@3"
        },
        {
          "command": "contenox.fixDiagnostics",
          "when": "!editorReadonly && contenox.hasDiagnostics && isWorkspaceTrusted",
          "group": "contenoxAction@4"
        },
        {
          "command": "contenox.explainDiagnostics",
          "when": "contenox.hasDiagnostics && isWorkspaceTrusted",
          "group": "contenoxAction@5"
        }
      ],
      "view/title": [
        {
          "command": "contenox.openChat",
          "when": "view == contenox.sessions",
          "group": "navigation@1"
        },
        {
          "command": "contenox.refreshSessions",
          "when": "view == contenox.sessions && contenox.connected",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "contenox.deleteSession",
          "when": "view == contenox.sessions && viewItem == contenoxSession",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "sync:metadata": "node scripts/sync-package-metadata.js",
    "vscode:prepublish": "npm run sync:metadata && npm run compile",
    "build": "npm run sync:metadata && npm run compile && npm run bundle:binary",
    "bundle:binary": "node scripts/build-binary.js",
    "compile": "node scripts/clean-dist.js && tsc -p .",
    "check": "tsc -p . --noEmit",
    "test": "npm run compile && vscode-test",
    "test:integration": "npm run test",
    "watch": "tsc -watch -p .",
    "package": "node scripts/package-target.js",
    "package:target": "node scripts/package-target.js",
    "package:check": "node scripts/assert-package-clean.js",
