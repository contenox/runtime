{
  "name": "@contenox/ui",
  "version": "0.6.5",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:css": "tailwindcss -i ./src/index.css -o ./dist/index.css",
    "build": "tsup src/index.ts --format cjs,esm --dts --external react,react-dom,clsx,tailwind-merge,lucide-react,tailwindcss,react-markdown --tsconfig tsconfig.json && npm run build:css",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "prettier": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "peerDependencies": {
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.5",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/react": "^19.0.10",
    "clsx": "^2.1.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "lucide-react": "^0.479.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.0",
    "tsc": "^2.0.4",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./chat": {
      "types": "./src/chat.ts",
      "import": "./src/chat.ts",
      "default": "./src/chat.ts"
    },
    "./tailwind-config": {
      "types": "./tailwind.config.d.ts",
      "import": "./tailwind.config.js"
    },
    "./styles.css": "./dist/index.css",
    "./theme.css": "./src/index.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "devDependencies": {
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "postcss": "^8.5.3",
    "react-markdown": "^10.1.0",
    "storybook": "^10.4.0",
    "vite": "^8.0.13"
  }
}
