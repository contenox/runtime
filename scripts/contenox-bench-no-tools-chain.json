{
  "id": "contenox-bench-no-tools",
  "description": "Single chat_completion task for same-model local backend benchmarks without tool schemas.",
  "tasks": [
    {
      "id": "answer",
      "handler": "chat_completion",
      "system_instruction": "Current date: {{date}}.\n\nAnswer the user directly and concisely.",
      "execute_config": {
        "model": "{{var:model}}",
        "provider": "{{var:provider}}",
        "think": "{{var:think}}",
        "shift": true,
        "tools": [],
        "max_tokens": "{{var:max_tokens|64}}",
        "retry_policy": {
          "max_attempts": 1
        }
      },
      "transition": {
        "branches": [
          {
            "operator": "default",
            "when": "",
            "goto": "end"
          }
        ]
      }
    }
  ]
}
