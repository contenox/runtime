---
import Base from '../../layouts/Base.astro';
import Landing from '../../components/Landing.astro';
import type { LandingStrings } from '../../components/Landing.astro';

const t: LandingStrings = {
  badge: 'Local-first KI-Workflow-Runtime',
  h1a: 'KI-Workflows, die du ausführst,',
  h1b: 'prüfst und besitzt.',
  lede: 'Verpacke wiederkehrende Entwicklungsarbeit in versionierte Chains, binde die Modelle und Tools deiner Wahl ein und führe sie über CLI, deinen Editor oder jeden ACP-Client aus — jeder riskante Schritt hinter einer Freigabe, die du kontrollierst. Kein gehosteter Contenox-Dienst nötig.',
  ctaRecipe: 'Rezept ausführen',
  ctaPackage: 'Workflow verpacken',
  ctaGithub: 'Auf GitHub ansehen',
  installNote: 'Installiert <code class="font-mono">contenox</code>. Mit <code class="font-mono">contenox init</code> richtest du einen Workspace ein.',
  positioning: 'Contenox ist kein Chatbot, keine bloße VS-Code-Erweiterung und kein Agent-Framework. Es ist eine local-first Workflow-Runtime für konkrete, überprüfbare KI-Arbeit.',
  tableWorld: 'Verwandte Welt',
  tableWhy: 'Was Contenox anders macht',
  rows: [
    ['Cursor / IDE-Copilots', 'Runtime-first statt Editor-first. Dieselbe Engine arbeitet im Terminal, in VS Code und in ACP-Clients.'],
    ['Aider / CLI-Coding-Agents', 'Breiterer Umfang bei Workflows, Sessions, Tool-Policies und Providern als eine einzelne Coding-Schleife.'],
    ['LangChain / Agent-Frameworks', 'Ein ausführbares Endnutzer-Produkt, nicht nur eine Bibliothek zum Einbauen.'],
    ['Dify / n8n / Web-Workflow-Tools', 'Lokal und Workspace-first statt Web-App oder SaaS-first.'],
    ['Ollama-Wrapper', 'Provider-neutral und auf Workflows, Tools und HITL ausgerichtet — mit lokalen und gehosteten Modellen.'],
  ],
  authorEyebrow: 'Was du bauen kannst',
  authorH2: 'Wiederholbare Arbeit, mit Policy in der Datei.',
  authorItems: [
    'Release-Evidenzpaket: Git-Historie, PRs, Ticketnotizen und CI-Ausgaben rein; die Chain entwirft Changelog, Risikohinweise und Deployment-Checkliste — und stoppt vor der Veröffentlichung.',
    'API-zu-Workflow-Wrapper: ein schmales OpenAPI-Subset registrieren, versteckte Workspace- oder Umgebungsargumente injizieren und Freigaben für schreibende Aufrufe verlangen.',
    'Repo-Wartungs-Chain: ein Issue analysieren, den Patch planen, nur freigegebene Dateien anfassen, Tests ausführen und ein Review-Paket vorbereiten, statt das Projekt still zu verändern.',
    'Browser-QA-Evidenz: Playwright erfasst den Live-Zustand der App, die Chain schreibt Doku oder Screenshots, und die Policy entscheidet, was menschliche Freigabe braucht.',
  ],
  editorsEyebrow: 'Dort, wo gearbeitet wird',
  editorsH2: 'Dieselbe Chain läuft im Editor, im Terminal oder in der Automatisierung.',
  editorsLede: 'Contenox bringt eine native VS-Code-Erweiterung mit und spricht das Agent Client Protocol über stdio für andere Editoren. Nutze VS Code, Zed, JetBrains oder AionUi, wenn eine Editor-Oberfläche hilft; der Workflow selbst bleibt in der Chain-Datei, Tool-Aufrufe und HITL-Freigaben laufen über den Client.',
  guides: [
    ['VS-Code-Erweiterung installieren', 'https://marketplace.visualstudio.com/items?itemName=contenox.contenox-runtime'],
    ['VS-Code-Anleitung lesen', '/docs/integrations/editors/vscode-vscodium/'],
    ['Zed-Anleitung lesen', '/docs/integrations/editors/zed/'],
    ['JetBrains-Anleitung lesen', '/docs/integrations/editors/jetbrains/'],
    ['AionUi-Anleitung lesen', '/docs/integrations/editors/aionui/'],
  ],
  capsEyebrow: 'Kernfähigkeiten',
  caps: [
    ['Die Chain ist der Vertrag', 'Prompts, Modell-Routing, Tool-Allowlists, Kommando-Policies, Budgets und Freigabe-Gates sind sichtbare Schlüssel in einer versionierten Datei — prüfbar, diffbar, wiederholbar.'],
    ['Läuft, wo gearbeitet wird', 'Eine Runtime hinter CLI, VS-Code-Erweiterung und jedem ACP-Editor. Dieselben Chains, Sessions und Policies überall.'],
    ['Provider sind Konfiguration', 'Inferenz läuft über lokales modeld, Ollama, vLLM, OpenAI, Anthropic, Mistral, Gemini, OpenRouter, Bedrock oder Vertex — ohne den Workflow anzufassen.'],
    ['Lokal als Standard', 'Sessions, Konfiguration, Run-Logs und Zustand liegen in SQLite auf deinem Rechner. Kein gehosteter Dienst, kein Konto — Telemetrie ist opt-in und standardmäßig aus.'],
  ],
  hitlDemoAlt: 'Terminal-Demo: Ein destruktives rm-Kommando stoppt vor der Ausführung an einem Freigabe-Gate',
  beamShotAlt: 'Beam-Web-UI: Eine Datei-Änderung des Agenten stoppt am Freigabe-Gate mit einem Diff der Änderung, wird live bestätigt, dann schaltet der Workspace-Baum in die Agent-Ansicht und markiert jede Datei mit ihrem Policy-Urteil',
  beamShotCaption: 'Live aus Beam, der mitgelieferten lokalen Web-UI: Die Datei-Änderung des Agenten stoppt am Freigabe-Gate mit einem Diff der exakten Änderung, wird direkt bestätigt, dann schaltet der Workspace-Baum in die Agent-Ansicht — jede Datei markiert als erlaubt, Freigabe nötig, blockiert oder unerreichbar. contenox serve öffnet dieselben Sessions, Chains und Backends im Browser.',
  beamEyebrow: 'Die mitgelieferte Web-UI',
  beamH2: 'Sieh die Arbeit. Bestätige den Diff.',
  beamLede: 'contenox serve öffnet die komplette Runtime im Browser — dieselben Sessions, Chains und Policies wie im CLI, lokal ausgeliefert und nie gehostet. In Beam siehst du, was der Agent tun will, bevor er es tut.',
  beamPoints: [
    ['Bestätige den Diff, nicht das Bauchgefühl', 'Jeder gegatete Schreibvorgang oder Befehl stoppt am Freigabe-Gate. Datei-Änderungen erscheinen als Diff der exakten Änderung — erlauben (Y) oder ablehnen (N). Nichts läuft, bevor du zustimmst.'],
    ['Sieh, was der Agent anfassen darf', 'Schalte den Workspace-Baum in die Agent-Ansicht, und jede Datei trägt ihr Policy-Urteil — erlaubt, Freigabe nötig, blockiert oder unerreichbar — berechnet aus derselben Policy, der der Agent live folgt.'],
    ['Eine Runtime, im Browser', 'In Beam gestartete Sessions sind die Sessions, die das CLI auflistet. Dateien und ein Workspace-Terminal öffnen als Tabs; Tool-Aufrufe und Fehler bleiben als Karten über Reloads erhalten.'],
  ],
  beamCta: 'Beam-Anleitung lesen',
  standardsEyebrow: 'Auf offenen Standards gebaut',
  standardsH2: 'Spricht die Protokolle, die deine Tools schon nutzen.',
  standards: [
    ['Agent Client Protocol', 'Die komplette Runtime in Zed, JetBrains, AionUi und jedem ACP-Client — über stdio, ohne Plugin-Lock-in.', 'https://agentclientprotocol.com'],
    ['Model Context Protocol', 'Registriere jeden MCP-Server — stdio, SSE oder HTTP — und seine Tools werden policy-begrenzte Chain-Tools.', 'https://modelcontextprotocol.io'],
    ['OpenAPI', 'Zeige auf einen HTTP-Dienst mit Spec, und jede Operation wird ein aufrufbares, allowlistbares Tool.', '/docs/integrations/tools/remote/'],
  ],
  bottomEyebrow: 'Loslegen',
  bottomH2: 'Besitze deine KI-Workflows — in den nächsten fünf Minuten.',
  bottomCta: 'Quickstart lesen',
  bottomContact: 'Fragen? <a href="mailto:hello@contenox.com" class="underline hover:text-black dark:hover:text-white">hello@contenox.com</a> · Issues und PRs auf <a href="https://github.com/contenox/runtime" class="underline hover:text-black dark:hover:text-white">GitHub</a>',
  builtOnEyebrow: 'Baut auf',
  builtOnNote: 'Lokale Inferenz linkt diese Upstream-Projekte zur Build-Zeit; ihre Laufzeitbibliotheken und Lizenztexte liegen jedem Release-Paket bei. Gehostete Provider werden über ihre öffentlichen APIs angebunden.',
  builtOn: [
    ['llama.cpp', 'GGUF-Inferenz · CPU/CUDA/HIP/Metal', 'https://github.com/ggml-org/llama.cpp'],
    ['OpenVINO', 'Inferenz-Runtime · CPU/iGPU', 'https://github.com/openvinotoolkit/openvino'],
    ['OpenVINO GenAI', 'LLM-Pipeline', 'https://github.com/openvinotoolkit/openvino.genai'],
    ['Go', 'die pure-Go-Runtime', 'https://go.dev'],
    ['SQLite', 'lokaler Zustand', 'https://sqlite.org'],
  ],
};
---
<Base
  title="Contenox - Local-first KI-Workflow-Runtime für Entwickler"
  description="Contenox — local-first KI-Workflow-Runtime. Verpacke wiederkehrende Arbeit in versionierte Chains und führe sie über CLI, VS Code oder jeden ACP-Editor aus."
  lang="de"
  alternates={{ en: '/', de: '/de/' }}
>
  <Landing t={t} />
</Base>
