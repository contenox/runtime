---
import { buildDocsTree } from '../lib/tree';
import SidebarNode from './SidebarNode.astro';

interface Props {
  current: string;
}
const { current } = Astro.props;
const tree = await buildDocsTree();
---
<nav aria-label="Documentation tree" class="text-sm">
  <p class="px-2 pb-2 font-mono text-xs text-neutral-500">docs/</p>
  <ul>
    {tree.children.map((node) => (
      <SidebarNode node={node} current={current} />
    ))}
  </ul>
</nav>
