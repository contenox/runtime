# The ollama Go module strips llama.cpp's vendored single-header deps
# (nlohmann/json, miniaudio, stb), so CGO can't compile it as-is. Fetch them
# locally and feed via CGO_CPPFLAGS. Required to build anything under -tags
# llamanode (the CGO llama.cpp backend / owned-ABI shim).
LLAMA_VENDOR ?= $(CURDIR)/.llamacpp-vendor

# Pin minja to the SAME llama.cpp commit ollama@v0.17.5 vendors (LLAMA_COMMIT in
# its build-info.cpp), so the model-native Jinja chat-template engine matches the
# linked llama.cpp. minja is the header-only engine llama.cpp itself uses to render
# a model's own chat template (including tool definitions) — the legacy
# llama_chat_apply_template cannot, so this is what enables model-native tool calls.
LLAMA_CPP_COMMIT ?= ec98e2002

vendor-headers:
	@mkdir -p "$(LLAMA_VENDOR)/nlohmann" "$(LLAMA_VENDOR)/miniaudio" "$(LLAMA_VENDOR)/stb" "$(LLAMA_VENDOR)/minja"
	@curl -fsSL -o "$(LLAMA_VENDOR)/nlohmann/json.hpp"     https://raw.githubusercontent.com/nlohmann/json/v3.11.3/single_include/nlohmann/json.hpp
	@curl -fsSL -o "$(LLAMA_VENDOR)/nlohmann/json_fwd.hpp" https://raw.githubusercontent.com/nlohmann/json/v3.11.3/single_include/nlohmann/json_fwd.hpp
	@curl -fsSL -o "$(LLAMA_VENDOR)/miniaudio/miniaudio.h" https://raw.githubusercontent.com/mackron/miniaudio/0.11.21/miniaudio.h
	@curl -fsSL -o "$(LLAMA_VENDOR)/stb/stb_image.h"       https://raw.githubusercontent.com/nothings/stb/master/stb_image.h
	@curl -fsSL -o "$(LLAMA_VENDOR)/minja/minja.hpp"         https://raw.githubusercontent.com/ggml-org/llama.cpp/$(LLAMA_CPP_COMMIT)/vendor/minja/minja.hpp
	@curl -fsSL -o "$(LLAMA_VENDOR)/minja/chat-template.hpp" https://raw.githubusercontent.com/ggml-org/llama.cpp/$(LLAMA_CPP_COMMIT)/vendor/minja/chat-template.hpp
	@echo "vendored llama.cpp headers -> $(LLAMA_VENDOR)"

# Build + run the owned-ABI shim test: proves it reads the model's own GGUF chat
# template + applies it + reads BOS policy. Set CONTENOX_LLAMA_TINY_GGUF.
test-shim: vendor-headers
	CGO_ENABLED=1 CGO_CPPFLAGS="-I$(LLAMA_VENDOR)" \
	go test -tags 'llamanode llama_unsafe_abi' -run TestShim -v ./modeld/llama/llamaabi/

test-abi-link: vendor-headers
	@echo "--- Running L0 Unsafe ABI Linkage Test ---"
	@go test -v -x -work -tags 'llamanode llama_unsafe_abi' ./modeld/llama/llamaabi 2>&1 | tee /tmp/llamaabi-build.log
	@go test -c -tags 'llamanode llama_unsafe_abi' -o /tmp/llamaabi.test ./modeld/llama/llamaabi
	@echo "--- Checking symbols in /tmp/llamaabi.test ---"
	nm -A /tmp/llamaabi.test | grep 'llama_state_seq_get_data' || echo "llama_state_seq_get_data not found in binary!"
	nm -A /tmp/llamaabi.test | grep 'llama_free' || echo "llama_free not found in binary!"
	ldd /tmp/llamaabi.test || true
	@echo "--- Linkage Test Complete ---"
